{
  "manifest_version": 3,
  "name": "Meet Captions Translator",
  "version": "2.0",
  "description": "Перехватывает субтитры Google Meet и переводит через OpenRouter",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://openrouter.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Captions Translator"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
